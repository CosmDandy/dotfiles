# Образец файла доступов для backup.sh.
#
# Скопировать в ~/.config/restic/env, заполнить и выставить права:
#   mkdir -p ~/.config/restic
#   cp automation/backup/env.example ~/.config/restic/env
#   chmod 600 ~/.config/restic/env
#
# ВСЕ четыре значения продублировать в Bitwarden отдельной записью. Этот файл —
# копия для автоматического запуска; канонический источник — менеджер паролей.
# Пароль репозитория, лежащий ТОЛЬКО внутри зашифрованного бэкапа, бесполезен:
# при потере мака им нечего будет расшифровать.

# Репозиторий на Hetzner Object Storage. Эндпойнт зависит от локации бакета —
# посмотреть в консоли Hetzner. Формат: s3:https://<локация>.your-objectstorage.com/<бакет>
# Локации: fsn1 (Falkenstein), nbg1 (Nürnberg), hel1 (Helsinki).
export RESTIC_REPOSITORY="s3:https://fsn1.your-objectstorage.com/ИМЯ_БАКЕТА"

# Пароль репозитория. Длинный, случайный. Сгенерировать: openssl rand -base64 32
# Меняешь его — теряешь доступ к уже снятым снапшотам. Задаётся при restic init.
export RESTIC_PASSWORD="СГЕНЕРИРОВАННЫЙ_ПАРОЛЬ"

# S3-ключи Hetzner Object Storage (создаются в консоли, раздел Credentials).
export AWS_ACCESS_KEY_ID="КЛЮЧ"
export AWS_SECRET_ACCESS_KEY="СЕКРЕТ"
