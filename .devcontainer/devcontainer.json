{
  // Тег намеренно плавающий: воркспейсы одноразовые, и пересоздание должно
  // сразу давать свежий образ (еженедельная пересборка в CI). Воспроизводимость
  // при этом не теряется — окружение задаёт flake.lock, а образ лишь ускоряет
  // старт: home-manager switch досыпет разницу, если store-пути разойдутся.
  // Откат на конкретную сборку — иммутабельным тегом <профиль>-<дата>-<sha7>,
  // список: docker buildx imagetools inspect ghcr.io/cosmdandy/devcontainer:devops
  "name": "Dotfiles DevContainer",
  "image": "ghcr.io/cosmdandy/devcontainer:devops",
  // docker сам НЕ перетягивает уже имеющийся локальный тег — без этого хоста
  // (сервер/OrbStack) навсегда залипали на первом скачанном образе (ловили
  // образ 5-дневной давности). initializeCommand бежит на хосте до создания
  // контейнера: дайджест не изменился — no-op за секунды; офлайн — едем на
  // локальном (|| true).
  "initializeCommand": "docker pull ghcr.io/cosmdandy/devcontainer:devops || true",
  "onCreateCommand": "bash .devcontainer/setup.sh",
  // containerEnv против remoteEnv: первый задаёт переменные всему контейнеру,
  // второй — только процессам, которые запускает инструмент. Локаль и таймзона
  // нужны и фоновым демонам, и `docker exec`, поэтому им место в containerEnv
  // (дублируют ENV пребилт-образа, но делают конфиг самодостаточным на голом).
  // TERM/COLORTERM — свойство конкретной терминальной сессии, их место здесь.
  "containerEnv": {
    "LANG": "en_US.UTF-8",
    "LC_ALL": "en_US.UTF-8",
    "TZ": "Europe/Moscow"
  },
  "remoteEnv": {
    "TERM": "xterm-256color",
    "COLORTERM": "truecolor"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": { "path": "/usr/bin/zsh" }
        }
      }
    }
  }
}
