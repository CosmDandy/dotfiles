font-size = 15
theme = light:iTerm2 Solarized Light,dark:iTerm2 Solarized Dark
cursor-color = 2aa198

fullscreen = true

mouse-hide-while-typing = true
clipboard-paste-protection = false

# keyboard-first: делаем мышь бесполезной, не запрещая физически
copy-on-select = false          # выделение мышью ничего не копирует
cursor-click-to-move = false    # клик в промпте не двигает курсор
mouse-scroll-multiplier = 0.01  # колесо прокрутки практически мёртвое
mouse-reporting = false         # приложения не получают события мыши

macos-option-as-alt = true
desktop-notifications = true
notify-on-command-finish = unfocused
notify-on-command-finish-after = 10s
bell-features = system,attention,title,border
keybind = shift+enter=text:\x1b\r
