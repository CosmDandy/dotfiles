font-size = 15
theme = light:iTerm2 Solarized Light,dark:iTerm2 Solarized Dark
cursor-color = 2aa198

fullscreen = true

mouse-hide-while-typing = true
clipboard-paste-protection = false

# keyboard-first: нейтрализуем мышь, но оставляем живой скролл
# (Claude Code/nvim/TUI листаются колесом через mouse-reporting)
# выделение мышью ничего не копирует
copy-on-select = false
# клик в промпте не двигает курсор
cursor-click-to-move = false

macos-option-as-alt = true
desktop-notifications = true
notify-on-command-finish = unfocused
notify-on-command-finish-after = 10s
bell-features = system,attention,title,border
keybind = shift+enter=text:\x1b\r
