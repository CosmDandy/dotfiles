font-size = 15
theme = light:iTerm2 Solarized Light,dark:iTerm2 Solarized Dark
cursor-color = 2aa198

fullscreen = true

mouse-hide-while-typing = true
clipboard-paste-protection = true
# OSC 52: приложения (nvim/tmux/Claude Code) читают буфер без запроса-диалога.
clipboard-read = allow

# Заголовок вкладки отдаём скрипту tab-title.zsh (иконки VM/контейнера).
# Отключаем только title-фичу; cursor/path/etc остаются.
shell-integration-features = no-title

# keyboard-first: нейтрализуем мышь, но оставляем живой скролл
# (Claude Code/nvim/TUI листаются колесом через mouse-reporting)
# выделение мышью ничего не копирует
copy-on-select = false
# клик в промпте не двигает курсор
cursor-click-to-move = false

macos-option-as-alt = true
desktop-notifications = true
notify-on-command-finish = unfocused
notify-on-command-finish-after = 10s
bell-features = system,attention,title,border
keybind = shift+enter=text:\x1b\r

# Quick Terminal (Quake-стиль): выезжает сверху по глобальному Option+F5, поверх любого приложения.
# Глобальный бинд требует разрешения Ghostty в System Settings → Privacy → Accessibility.
quick-terminal-position = top
keybind = global:alt+f5=toggle_quick_terminal

font-family = "JetBrainsMono Nerd Font"