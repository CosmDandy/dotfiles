[Unit]
Description=Claude Code overnight runner
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
# %h — домашний каталог пользователя
ExecStart=%h/dotfiles/tools/claude/overnight/overnight.sh
# При необходимости задать модель/репо:
# Environment=OVERNIGHT_MODEL=opus
# Environment=OVERNIGHT_REPO=%h/dotfiles
# Жёсткий потолок по времени, чтобы зависший прогон не висел до утра:
TimeoutStartSec=3h
